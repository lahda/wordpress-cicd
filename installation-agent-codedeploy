sudo apt-get update -y

# Installer Ruby et Wget (requis pour CodeDeploy)
sudo apt-get install -y ruby wget

# Aller dans le répertoire home
cd /home/ubuntu

# Télécharger l'installateur CodeDeploy (région us-east-1)
wget https://aws-codedeploy-us-east-1.s3.us-east-1.amazonaws.com/latest/install

# Rendre l'installateur exécutable
chmod +x ./install

# Installer l'agent CodeDeploy
sudo ./install auto

# Démarrer l'agent
sudo systemctl start codedeploy-agent

# Activer au démarrage
sudo systemctl enable codedeploy-agent

# Vérifier que l'agent fonctionne
sudo systemctl status codedeploy-agent
```

